TRACEOPS_ENV=local
TRACEOPS_API_PORT=8000

POSTGRES_DB=traceops
POSTGRES_USER=traceops
POSTGRES_PASSWORD=traceops_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg://traceops:traceops_dev_password@postgres:5432/traceops

REDIS_URL=redis://redis:6379/0

STORAGE_PROVIDER=minio

MINIO_ROOT_USER=traceops
MINIO_ROOT_PASSWORD=traceops_minio_password
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=127.0.0.1:9000
MINIO_BUCKET=traceops-local
MINIO_SECURE=false
S3_REGION=us-east-1

SUPABASE_STORAGE_ENDPOINT=
SUPABASE_STORAGE_PUBLIC_ENDPOINT=
SUPABASE_STORAGE_BUCKET=traceops-evidences
SUPABASE_STORAGE_ACCESS_KEY_ID=
SUPABASE_STORAGE_SECRET_ACCESS_KEY=
SUPABASE_STORAGE_REGION=us-east-1
SUPABASE_STORAGE_SECURE=true

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
BOOTSTRAP_ENABLED=true
